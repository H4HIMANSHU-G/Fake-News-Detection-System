# %%
    # Fake news prediction using Logistic Regression 
    # About the Dataset:
    # 1. id. The unique id of the news article.
    # 2. title. The title of the news article.
    # 3. author. The author of the news article.
    # 4. text. The text of the news article.
    # 5. label. The label of the news article, where 0 is real and 1 is fake.
    #     0 = Real News
    #     1 = Fake News

# Importing the dependencies
import numpy as np
import pandas as pd
import re
from nltk.corpus import stopwords
from nltk.stem.porter import PorterStemmer
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score


# %%
import nltk
nltk.download('stopwords')

# %%
print(stopwords.words('english'))

# %%
df = pd.read_csv(r"C:\Users\anil kumar singh\OneDrive\Desktop\Fake news\Fake_News__Dataset.csv")
print(df.shape)
print(df.head(5))

# %%
# counting the missing values
print(df.isnull().sum())

# %%
# replacing the null value with empty string
df = df.fillna('')

# %%
# merging the author name and news title
df['content'] = df['author'] + ' ' + df['title']

# %%
print(df['content'].head(5))

# %%
# Separating the data & label
X = df.drop(columns=['label'])
Y = df['label']

# %%
print(X)
print(Y)

# %%
# Stemming :
#     Stemming is the process of reducing a word to its Root word
# example : 
# actor , actress , acting , acted  --> act

# %%
port_stem = PorterStemmer()

# %%
def steming(content):
    stemmed_content = re.sub('[^a-zA-Z]', ' ', content)
    stemmed_content = stemmed_content.lower()
    stemmed_content = stemmed_content.split()
    
    stemmed_content = [port_stem.stem(word) for word in stemmed_content if not word in stopwords.words('english')]
    stemmed_content = ' '.join(stemmed_content)
    return stemmed_content
    
    

# %%
df['content'] = df['content'].apply(steming)
print(df['content'].head(5))

# %%
# Separating the data and label
X = df['content'].values
Y = df['label'].values

# %%
print(X)

# %%
print(Y)

# %%
Y.shape

# %%
# Converting the actual data to feature vectors
vectorizer = TfidfVectorizer()
X = vectorizer.fit_transform(X)

# %%
print(X)

# %%
# Splitting the dataset to training & test data
X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.2, stratify=Y, random_state=2)


# %%
# Train the model : Logistic Regression
model = LogisticRegression()

# %%
model.fit(X_train, Y_train)

# %%
# Evaluating the model : Accuracy Score
X_train_prediction = model.predict(X_train)
training_data_accuracy = accuracy_score(X_train_prediction, Y_train)
print('Accuracy score of the training data : ', training_data_accuracy)

# %%
# Accuracy score of the test data
X_test_prediction = model.predict(X_test)
test_data_accuracy = accuracy_score(X_test_prediction, Y_test)
print('Accuracy score of the test data : ', test_data_accuracy)

# %%
# Making a predictive System
X_new = X_test[3]
prediction = model.predict(X_new)
if (prediction[0] == 0):
    print('The news is Real')
else:    print('The news is Fake')


# %%
print(X_test[3])

# %%
print(Y_test[1])

# %%
# About the project:
# This project is about predicting whether the news is real or fake using Logistic Regression. 
# The dataset used in this project is the Fake News Dataset which contains news articles labeled as real or fake. 
# The model is trained on the content of the news articles and then evaluated on the test data. Finally, a predictive system is created to predict whether a new news article is real or fake based on its content.

# %%
# Testing with sample news articles
# Create sample news data for testing
test_news = [
    "John Smith Latest scientific research confirms the effectiveness of new vaccine",
    "Jane Doe Shocking revelations nobody wants to hear about celebrity",
    "Mike Johnson Government officials announce new policy on climate change",
    "Sarah Williams Unbelievable trick doctors hate revealed online"
]

print("="*80)
print("Testing the Fake News Prediction Model")
print("="*80)

for i, news in enumerate(test_news, 1):
    # Step 1: Apply stemming to the news
    processed_news = steming(news)
    
    # Step 2: Vectorize using the trained vectorizer
    news_vector = vectorizer.transform([processed_news])
    
    # Step 3: Make prediction
    prediction = model.predict(news_vector)[0]
    confidence = model.predict_proba(news_vector)[0]
    
    # Step 4: Display results
    result = "FAKE NEWS" if prediction == 1 else "REAL NEWS"
    print(f"\nTest {i}:")
    print(f"News: {news}")
    print(f"Prediction: {result}")
    print(f"Confidence: {confidence[prediction]:.2%}")
    print("-"*80)



